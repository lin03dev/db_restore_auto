# Application
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8002
RELOAD=true

# API authentication (required when ENVIRONMENT=production)
API_KEY=change-me-in-production

# CORS (comma-separated origins) — match frontend dev port
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Local PostgreSQL target (used for restore). If LOCAL_DB_PASSWORD is empty,
# the app falls back to local_postgres.password in config/databases.yaml.
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=your_local_password

# Remote source databases (referenced by config/databases.yaml)
AG_PROD_CONNECTION=postgresql://username:password@host:port/database?sslmode=require
TELIOS_PROD_CONNECTION=postgresql://username:password@host:port/database?sslmode=require
LMS_PROD_CONNECTION=postgresql://username:password@host:port/database?sslmode=require

# Policy
BACKUP_MAX_AGE_DAYS=7
RESTORE_COOLDOWN_DAYS=7
BACKUP_TIMEOUT_SECONDS=7200
REMOTE_CONNECTION_TIMEOUT_SECONDS=20
LOCAL_CONNECTION_TIMEOUT_SECONDS=15
MAX_JOBS=50

# Logging
LOG_LEVEL=INFO
