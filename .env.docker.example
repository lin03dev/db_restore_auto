# Copy to .env.docker — use: docker compose --env-file .env.docker up -d --build
# Public hosting guide: ../docker/public-hosting.md

BIND_ADDRESS=0.0.0.0
# PUBLIC_URL=https://restore.yourdomain.com
# CORS_ORIGINS=https://restore.yourdomain.com

ENVIRONMENT=development
HOST=0.0.0.0
PORT=8002
RELOAD=false

API_KEY=

CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

LOCAL_DB_HOST=host.docker.internal
LOCAL_DB_PORT=5432
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=YOUR_PASSWORD

AG_PROD_CONNECTION=postgresql://user:pass@host:5432/db?sslmode=require
TELIOS_PROD_CONNECTION=postgresql://user:pass@host:5432/db?sslmode=require
LMS_PROD_CONNECTION=postgresql://user:pass@host:5432/db?sslmode=require

BACKUP_MAX_AGE_DAYS=7
RESTORE_COOLDOWN_DAYS=7
BACKUP_TIMEOUT_SECONDS=7200
REMOTE_CONNECTION_TIMEOUT_SECONDS=20
LOCAL_CONNECTION_TIMEOUT_SECONDS=15
MAX_JOBS=50
LOG_LEVEL=INFO

RESTORE_WEB_PORT=5174

# Public internet: ENVIRONMENT=production, API_KEY set, rebuild web image
