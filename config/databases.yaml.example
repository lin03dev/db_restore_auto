databases:
  - name: "AG"
    source_dump: "AG_Prod.dump"
    target_db: "AG_Dev"
    enabled: true
    source_config:
      connection_string_env: "AG_PROD_CONNECTION"
      pg_dump_path: "pg_dump"
      
  - name: "Telios"
    source_dump: "Telios_LMS_Survey_Prod.dump"
    target_db: "Telios_LMS_Survey_Dev"
    enabled: true
    source_config:
      connection_string_env: "TELIOS_PROD_CONNECTION"
      pg_dump_path: "/usr/lib/postgresql/16/bin/pg_dump"

local_postgres:
  host: "localhost"
  port: 5432
  username: "postgres"
  password: "postgres"  # Override with env var in production
