# Local PostgreSQL settings
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=your_local_password

# AG Source Database (DigitalOcean)
AG_CONNECTION_STRING=postgresql://username:password@host:port/database?sslmode=require
PG_DUMP_PATH_AG=pg_dump

# Telios Source Database
TELIOS_CONNECTION_STRING=postgresql://username:password@host:port/database?sslmode=require
PG_DUMP_PATH_TELIOS=/usr/lib/postgresql/16/bin/pg_dump

# Schedule settings (24-hour format)
BACKUP_SCHEDULE=0 2 * * *
RESTORE_SCHEDULE=0 3 * * *

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
